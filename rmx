#!/usr/bin/env bash
# Null · rmx (crypto-shredding)
# encrypt on delete, key cleanup on recover/empty

set -euo pipefail # Be carefull

_dir="$HOME/.local/share/Trash" # Shows Trash Location
_crypto=true
_lock_file="${XDG_RUNTIME_DIR:-/tmp}/trash-lock-$(id -u).flock" # Wait for your turn

# when /dev/shm is usable, keys live in RAM (reboot => keys gone)
if [[ -d /dev/shm && -w /dev/shm ]]; then
  _keys="/dev/shm/.trash-keys-$(id -u)"
else
  _crypto=false
fi

# --- dependencies (fail-fast) ---
command -v flock >/dev/null 2>&1 || { echo "  error: flock not found" >&2; exit 1; } # Everything installed?
if $_crypto; then
  command -v base64 >/dev/null 2>&1 || { echo "  error: base64 not found" >&2; exit 1; }
  command -v openssl >/dev/null 2>&1 || { echo "  error: openssl not found" >&2; exit 1; }
fi

# --- init ---
_init() { # checking everything
  mkdir -p "$_dir"
  if $_crypto; then
    # keys file unwritable? degrade to plain mv
    if ! { touch "$_keys" && chmod 600 "$_keys"; } 2>/dev/null; then
      _crypto=false
    fi
  fi
}

# --- encoding ---
# base64 encode filename - safe for any character in key storage
_b64enc() {
  printf '%s' "$1" | base64 | tr -d '\n'
}

# --- key management ---
# remove a key entry after successful recover (atomic via tmp+mv)
_drop_key_entry() {
  local enc_name="$1" tmp
  tmp="$(mktemp "${_keys}.tmp.XXXXXX")" || return 1
  if awk -F'\t' -v n="$enc_name" '!( $1 == "v1" && $2 == n )' "$_keys" > "$tmp"; then
    if mv -- "$tmp" "$_keys"; then
      chmod 600 "$_keys" 2>/dev/null || true
      [[ -s "$_keys" ]] || rm -f -- "$_keys"    # empty? remove entirely
      return 0
    fi
  fi
  rm -f -- "$tmp"
  return 1
}

# --- locking ---
_lock_trash() {
  exec 9>>"$_lock_file"
  flock -x 9
}

_unlock_trash() {
  flock -u 9 2>/dev/null || true
  exec 9>&- || true
}

# --- encrypt and remove single item ---
_trash_one() {
  local f="$1" base name n key enc_name # Only 1 file

  _lock_trash
  base="$(basename -- "$f")"
  name="$base"
  n=1
  # collision avoidance: file.txt → file.txt.1 → file.txt.2
  while [[ -e "$_dir/$name.enc" || -e "$_dir/$name" ]]; do
    name="${base}.${n}"
    ((n++))
  done

  if $_crypto; then
    key=$(openssl rand -hex 32 2>/dev/null) || key=""
    if [[ -n "$key" ]]; then
      if [[ -d "$f" ]]; then
        # directory: tar then encrypt (fd:3 keeps key out of /proc/PID/cmdline)
        if tar cf - -C "$(dirname -- "$f")" "$(basename -- "$f")" 2>/dev/null \
          | openssl enc -aes-256-cbc -salt -pbkdf2 -pass "fd:3" -out "$_dir/$name.enc" 3<<< "$key" 2>/dev/null; then
          enc_name="$(_b64enc "$name")"
          printf 'v1\t%s\t%s\t%s\n' "$enc_name" "$key" "d" >> "$_keys"
          if ! rm -rf -- "$f"; then
            _unlock_trash
            return 1
          fi
          _unlock_trash
          return 0
        fi
        rm -f -- "$_dir/$name.enc" 2>/dev/null || true    # orphan cleanup
      else
        # file: encrypt directly
        if openssl enc -aes-256-cbc -salt -pbkdf2 -pass "fd:3" -in "$f" -out "$_dir/$name.enc" 3<<< "$key" 2>/dev/null; then
          enc_name="$(_b64enc "$name")"
          printf 'v1\t%s\t%s\t%s\n' "$enc_name" "$key" "f" >> "$_keys"
          # symlink: rm only (shred would destroy target)
          if [[ -L "$f" ]]; then
            rm -f -- "$f" || { _unlock_trash; return 1; }
          else
            shred -u -- "$f" 2>/dev/null || rm -f -- "$f" || { _unlock_trash; return 1; }
          fi
          _unlock_trash
          return 0
        fi
        rm -f -- "$_dir/$name.enc" 2>/dev/null || true    # orphan cleanup
      fi
    fi
  fi

  # fallback: no crypto available, plain move
  if mv -- "$f" "$_dir/$name"; then
    _unlock_trash
    return 0
  fi

  _unlock_trash
  return 1
}

# --- Delete multiple filees ---
_trash() {
  [[ $# -eq 0 ]] && { echo "  usage: rmx <file ...>" >&2; return 1; }
  _init

  local rc=0
  for f in "$@"; do
    [[ ! -e "$f" && ! -L "$f" ]] && { echo "  error: '$f' not found" >&2; rc=1; continue; }
    _trash_one "$f" || { echo "  error: failed to remove '$f'" >&2; rc=1; }
  done
  return $rc
}

# --- rmx recover <filename> ---
_recover() {
  [[ -z "${1:-}" ]] && { echo "  usage: rmx recover <filename>" >&2; return 1; }
  $_crypto || { echo "  error: no /dev/shm (crypto disabled)" >&2; return 1; }
  local name="$1" enc_name
  enc_name="$(_b64enc "$name")"
  _lock_trash

  [[ ! -f "$_keys" ]] && { _unlock_trash; echo "  error: no keys (rebooted?)" >&2; return 1; } # checking key file
  [[ ! -f "$_dir/$name.enc" ]] && { _unlock_trash; echo "  error: '$name' not found" >&2; return 1; }

  # lookup key by base64-encoded name (exact match, last entry wins)
  local entry key type
  entry="$(awk -F'\t' -v n="$enc_name" '$1 == "v1" && $2 == n { print $0 }' "$_keys" | tail -1)"
  key=$(printf '%s' "$entry" | cut -d$'\t' -f3)
  type=$(printf '%s' "$entry" | cut -d$'\t' -f4)
  type="${type:-f}"

  [[ -z "$key" ]] && { _unlock_trash; echo "  error: key not found for '$name'" >&2; return 1; }
  [[ -e "$name" ]] && { _unlock_trash; echo "  error: '$name' already exists in CWD" >&2; return 1; }

  # decrypt, then cleanup .enc + key entry (restore + cleanup semantics)
  if [[ "$type" == "d" ]]; then
    if openssl enc -d -aes-256-cbc -pbkdf2 -pass "fd:3" -in "$_dir/$name.enc" 3<<< "$key" 2>/dev/null | tar xf -; then
      rm -f -- "$_dir/$name.enc" 2>/dev/null || true
      _drop_key_entry "$enc_name" || { _unlock_trash; echo "  error: key cleanup failed for '$name'" >&2; return 1; }
      _unlock_trash
      echo "  recovered: $name/"
    else
      _unlock_trash
      echo "  error: decryption failed" >&2
      return 1
    fi
  else
    if openssl enc -d -aes-256-cbc -pbkdf2 -pass "fd:3" -in "$_dir/$name.enc" -out "$name" 3<<< "$key" 2>/dev/null; then
      rm -f -- "$_dir/$name.enc" 2>/dev/null || true
      _drop_key_entry "$enc_name" || { _unlock_trash; echo "  error: key cleanup failed for '$name'" >&2; return 1; }
      _unlock_trash
      echo "  recovered: $name"
    else
      _unlock_trash
      echo "  error: decryption failed" >&2
      return 1
    fi
  fi
}

# --- rmx list ---
_list() {
  $_crypto || { echo "  no /dev/shm (crypto disabled, no recovery)"; return 0; }
  [[ ! -f "$_keys" ]] && { echo "  no keys (rebooted or empty)"; return 0; }
  echo "  recoverable (keys in RAM):"
  local ver b64 key type name
  while IFS=$'\t' read -r ver b64 key type; do
    [[ "$ver" == "v1" ]] || continue
    name="$(printf '%s' "$b64" | base64 -d 2>/dev/null)"
    printf '    %s\n' "${name:-$b64}"
  done < "$_keys"
}

# --- rmx empty ---
_empty() {
  mkdir -p "$_dir"
  _lock_trash
  if [[ -z "$(ls -A "$_dir" 2>/dev/null)" ]]; then
    _unlock_trash
    echo "  rmx is already empty"
    return 0
  fi
  du -sh "$_dir"
  printf "  permanently delete all? [y/N] "
  read -r answer
  [[ "$answer" =~ ^[Yy]$ ]] || { _unlock_trash; echo "  cancelled"; return 0; }

  # destroy keys file (one 32-byte key per encrypted item)
  if $_crypto && [[ -f "$_keys" ]]; then
    shred -u "$_keys" 2>/dev/null || rm -f "$_keys"
  fi
  # remove all items (find handles dotfiles, * glob does not)
  find "${_dir:?}" -mindepth 1 -delete
  # wipe thumbnail cache
  rm -rf "${HOME}/.cache/thumbnails/"* 2>/dev/null || true
  _unlock_trash
  echo "  emptied (crypto-shredded)"
}

# --- dispatch ---
case "${1:-}" in
  recover) shift; _recover "$@" ;;
  list)    _list ;;
  empty)   _empty ;;
  -h|--help)
    echo "usage: rmx <file ...>"
    echo "       rmx recover <filename>"
    echo "       rmx list"
    echo "       rmx empty"
    ;;
  *)       _trash "$@" ;;
esac